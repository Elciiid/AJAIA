# --- Database ---
# Local dev (matches docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ajaia_docs?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ajaia_docs?schema=public"

# Production (Supabase): use the POOLED connection (port 6543) for DATABASE_URL
# and the DIRECT connection (port 5432) for DIRECT_URL. The app uses a dedicated
# "ajaia_docs" schema, so keep the schema= param on BOTH urls (it isolates this
# app from anything else in the project's public schema).
# DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=ajaia_docs"
# DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres?schema=ajaia_docs"

# --- Session ---
# 32+ character secret used to encrypt the iron-session cookie.
SESSION_SECRET="dev-only-change-me-to-a-long-random-string-min-32-chars"
